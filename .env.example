# Server environment variables — copy to server/.env for local dev
# On Railway/Render, set these in your service's environment variables panel

PORT=5000
NODE_ENV=development

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Frontend URL — set to your Vercel deployment URL in production
# Example: https://lasustech.vercel.app
CLIENT_URL=http://localhost:3000